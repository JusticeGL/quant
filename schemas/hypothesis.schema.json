{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Factor Mining Hypothesis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "round_number", "factor_id", "title",
    "hypothesis", "rationale", "primary_change", "changed_variable",
    "parent_factor_ids", "inputs", "lookback", "direction", "family",
    "formula", "expected_effect", "falsification_criteria", "created_at"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 3},
    "round_number": {"type": "integer", "minimum": 1},
    "factor_id": {"type": "string", "pattern": "^F[0-9]{4}$"},
    "title": {"type": "string", "minLength": 5},
    "hypothesis": {"type": "string", "minLength": 10},
    "rationale": {"type": "string", "minLength": 10},
    "primary_change": {
      "enum": ["new_factor", "operator", "window", "combination"]
    },
    "changed_variable": {"type": "string", "minLength": 2},
    "parent_factor_ids": {
      "type": "array", "items": {"type": "string", "pattern": "^F[0-9]{4}$"}
    },
    "inputs": {"type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string"}},
    "lookback": {"type": "integer", "minimum": 1},
    "direction": {"enum": [-1, 1]},
    "family": {"type": "string", "minLength": 2},
    "formula": {"type": "string", "minLength": 3},
    "expected_effect": {"type": "string", "minLength": 5},
    "falsification_criteria": {
      "type": "array", "minItems": 1, "items": {"type": "string"}
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
